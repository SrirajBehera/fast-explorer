# ─────────────────────────────────────────────────────────────────────────────
# Fast Explorer — .gitignore
# Covers: Vite/React frontend + Tauri/Rust backend + macOS system files
# ─────────────────────────────────────────────────────────────────────────────

# ── Node / Frontend ──────────────────────────────────────────────────────────
node_modules/
dist/
dist-ssr/
*.local

# npm / yarn / pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
logs/
*.log

# Vite cache
.vite/

# ── Rust / Tauri Backend ─────────────────────────────────────────────────────
# Rust build artifacts (gigabytes — NEVER commit)
target/
src-tauri/target/

# Tauri generated resources (rebuilt at compile time)
src-tauri/WixTools/
src-tauri/gen/

# ── SQLite Database Files ─────────────────────────────────────────────────────
# Runtime index DBs — machine-specific, rebuilt on first launch
*.db
*.db-shm
*.db-wal
fex.db
fex.db-shm
fex.db-wal
src-tauri/fex.db
src-tauri/fex.db-shm
src-tauri/fex.db-wal

# ── Stale Root-Level Rust Artifacts (Tauri backend lives in src-tauri/) ───────
# These can appear from early scaffolding — the real manifests are in src-tauri/
/Cargo.toml
/Cargo.lock
/scratch.rs

# ── Scratch / Temp Files ──────────────────────────────────────────────────────
scratch.rs
scratch.*
*.scratch
.scratch/
tmp/
temp/

# ── macOS System Files ────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.AppleDouble
.LSOverride
Icon

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
.project
.classpath
.settings/
*.iml
*.iws

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.*
!.env.example
*.pem
*.key
*.cert

# ── TypeScript Build Artifacts ────────────────────────────────────────────────
*.tsbuildinfo

# ── Test Coverage ─────────────────────────────────────────────────────────────
coverage/
.nyc_output/
